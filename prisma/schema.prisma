generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model LeadSession {
  id              String           @id
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  firstSeenAt     DateTime         @default(now())
  lastSeenAt      DateTime         @default(now())
  landingPage     String?
  referrer        String?
  source          String?
  medium          String?
  campaign        String?
  term            String?
  content         String?
  county          String?
  productInterest ProductInterest?
  contactId       String?
  events          Event[]
  inquiries       Inquiry[]
  contact         Contact?         @relation(fields: [contactId], references: [id])
  systemEvents    SystemEvent[]

  @@index([source, medium, campaign])
  @@index([county])
  @@index([contactId])
}

model Contact {
  id                   String                @id @default(uuid())
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  email                String?               @unique
  firstName            String?
  lastName             String?
  fullName             String?
  phone                String?
  county               String?
  primarySource        String?
  primaryMedium        String?
  primaryCampaign      String?
  primarySourceType    LeadSource            @default(UNKNOWN)
  primaryIntent        LeadIntent            @default(UNKNOWN)
  currentIntent        LeadIntent            @default(UNKNOWN)
  status               LeadStatus            @default(NEW)
  leadScore            Int                   @default(0)
  lastActivityAt       DateTime?
  nextFollowUpAt       DateTime?
  notesSummary         String?
  aiRuns               AiRun[]
  appointments         Appointment[]
  calendarEvents       CalendarEvent[]
  conversationMessages ConversationMessage[]
  conversationThreads  ConversationThread[]
  emailLogs            EmailLog[]
  events               Event[]
  inquiries            Inquiry[]
  leadSessions         LeadSession[]
  notes                Note[]
  systemEvents         SystemEvent[]
  tasks                Task[]

  @@index([createdAt])
  @@index([county])
  @@index([phone])
  @@index([leadScore])
  @@index([lastActivityAt])
  @@index([primarySourceType])
  @@index([primaryIntent])
  @@index([currentIntent])
  @@index([status])
}

model Inquiry {
  id              String                @id @default(uuid())
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  contactId       String
  leadSessionId   String?
  stage           PipelineStage         @default(New)
  productInterest ProductInterest       @default(General)
  source          String?
  medium          String?
  campaign        String?
  sourceType      LeadSource            @default(UNKNOWN)
  intent          LeadIntent            @default(UNKNOWN)
  status          LeadStatus            @default(NEW)
  landingPage     String?
  county          String?
  notes           String?
  leadScore       Int                   @default(0)
  aiRuns          AiRun[]
  appointments    Appointment[]
  calendarEvents  CalendarEvent[]
  messages        ConversationMessage[]
  threads         ConversationThread[]
  events          Event[]
  contact         Contact               @relation(fields: [contactId], references: [id])
  leadSession     LeadSession?          @relation(fields: [leadSessionId], references: [id])
  history         InquiryStageHistory[]
  notesEntries    Note[]
  systemEvents    SystemEvent[]
  tasks           Task[]

  @@index([createdAt])
  @@index([stage])
  @@index([productInterest])
  @@index([source, medium, campaign])
  @@index([county])
  @@index([contactId])
  @@index([leadScore])
  @@index([sourceType])
  @@index([intent])
  @@index([status])
}

model Appointment {
  id              String          @id @default(uuid())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  contactId       String
  inquiryId       String?
  bookingSource   String?
  source          String?
  medium          String?
  campaign        String?
  scheduledFor    DateTime?
  status          String          @default("Booked")
  location        String?
  calendlyEventId String?
  metadata        Json?
  contact         Contact         @relation(fields: [contactId], references: [id])
  inquiry         Inquiry?        @relation(fields: [inquiryId], references: [id])
  calendarEvents  CalendarEvent[]

  @@index([createdAt])
  @@index([scheduledFor])
  @@index([status])
}

model Task {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  title       String
  description String?
  status      String    @default("Open")
  dueAt       DateTime?
  inquiryId   String?
  contactId   String?
  contact     Contact?  @relation(fields: [contactId], references: [id])
  inquiry     Inquiry?  @relation(fields: [inquiryId], references: [id])

  @@index([status])
  @@index([dueAt])
}

model Event {
  id              String           @id @default(uuid())
  createdAt       DateTime         @default(now())
  eventType       EventType
  contactId       String?
  inquiryId       String?
  leadSessionId   String?
  pageUrl         String?
  referrer        String?
  source          String?
  medium          String?
  campaign        String?
  county          String?
  productInterest ProductInterest?
  metadata        Json?
  occurredAt      DateTime         @default(now())
  contact         Contact?         @relation(fields: [contactId], references: [id])
  inquiry         Inquiry?         @relation(fields: [inquiryId], references: [id])
  leadSession     LeadSession?     @relation(fields: [leadSessionId], references: [id])

  @@index([occurredAt])
  @@index([eventType, occurredAt])
  @@index([source, medium, campaign])
  @@index([county])
  @@index([contactId])
  @@index([inquiryId])
  @@index([leadSessionId])
}

model SystemEvent {
  id            String              @id @default(uuid())
  createdAt     DateTime            @default(now())
  occurredAt    DateTime            @default(now())
  type          String
  contactId     String?
  inquiryId     String?
  leadSessionId String?
  threadId      String?
  source        String?
  medium        String?
  campaign      String?
  payload       Json
  metadata      Json?
  contact       Contact?            @relation(fields: [contactId], references: [id])
  inquiry       Inquiry?            @relation(fields: [inquiryId], references: [id])
  leadSession   LeadSession?        @relation(fields: [leadSessionId], references: [id])
  thread        ConversationThread? @relation(fields: [threadId], references: [id])

  @@index([type, occurredAt])
  @@index([contactId])
  @@index([inquiryId])
}

model ConversationThread {
  id             String                @id @default(uuid())
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  contactId      String
  inquiryId      String?
  channel        ThreadChannel
  externalId     String?
  subject        String?
  lastMessageAt  DateTime?
  lastInboundAt  DateTime?
  lastOutboundAt DateTime?
  isArchived     Boolean               @default(false)
  messages       ConversationMessage[]
  contact        Contact               @relation(fields: [contactId], references: [id])
  inquiry        Inquiry?              @relation(fields: [inquiryId], references: [id])
  systemEvents   SystemEvent[]

  @@index([contactId, updatedAt])
  @@index([channel])
}

model ConversationMessage {
  id                String             @id @default(uuid())
  createdAt         DateTime           @default(now())
  threadId          String
  contactId         String?
  inquiryId         String?
  direction         MessageDirection
  channel           ThreadChannel
  status            MessageStatus?
  subject           String?
  bodyText          String?
  providerMessageId String?
  fromAddress       String?
  toAddress         String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  metadata          Json?
  contact           Contact?           @relation(fields: [contactId], references: [id])
  inquiry           Inquiry?           @relation(fields: [inquiryId], references: [id])
  thread            ConversationThread @relation(fields: [threadId], references: [id])

  @@index([threadId, createdAt])
  @@index([contactId])
}

model AiRun {
  id           String      @id @default(uuid())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  type         AiRunType
  status       AiRunStatus @default(queued)
  model        String?
  contactId    String?
  inquiryId    String?
  input        Json
  output       Json?
  tokensInput  Int?
  tokensOutput Int?
  latencyMs    Int?
  error        String?
  contact      Contact?    @relation(fields: [contactId], references: [id])
  inquiry      Inquiry?    @relation(fields: [inquiryId], references: [id])
  agentSteps   AgentWorkflowStep[]

  @@index([type, createdAt])
  @@index([status])
  @@index([contactId])
}

model AgentWorkflowStep {
  id          String           @id @default(uuid())
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  aiRunId     String
  order       Int
  agentRole   String
  task        String
  status      AgentStepStatus  @default(pending)
  output      Json?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  aiRun       AiRun            @relation(fields: [aiRunId], references: [id], onDelete: Cascade)

  @@index([aiRunId, order])
  @@index([status])
}

model Note {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  contactId String?
  inquiryId String?
  title     String?
  body      String
  author    String?
  isPinned  Boolean  @default(false)
  contact   Contact? @relation(fields: [contactId], references: [id])
  inquiry   Inquiry? @relation(fields: [inquiryId], references: [id])

  @@index([contactId, createdAt])
  @@index([inquiryId, createdAt])
}

model InquiryStageHistory {
  id        String         @id @default(uuid())
  changedAt DateTime       @default(now())
  inquiryId String
  fromStage PipelineStage?
  toStage   PipelineStage
  actor     String?
  note      String?
  inquiry   Inquiry        @relation(fields: [inquiryId], references: [id])

  @@index([inquiryId, changedAt])
}

model EmailLog {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())
  contactId  String?
  toAddr     String
  fromAddr   String
  subject    String
  template   String?
  status     String
  providerId String?
  error      String?
  contact    Contact? @relation(fields: [contactId], references: [id])

  @@index([contactId])
  @@index([status])
}

model ContentAsset {
  id              String           @id @default(uuid())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  title           String
  type            ContentType
  status          ContentStatus    @default(draft)
  channel         String?
  audience        String?
  campaign        String?
  productInterest ProductInterest?
  prompt          String?
  bodyText        String?
  bodyHtml        String?
  metadata        Json?
  scheduledFor    DateTime?
  publishedAt     DateTime?
  createdBy       String?

  @@index([type, status])
  @@index([campaign])
  @@index([scheduledFor])
}

model MarketingContent {
  id          String   @id @default(cuid())
  title       String
  bodyHtml    String
  campaign    String?
  destination String?
  utmSource   String?
  type        String   @default("post")
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([campaign])
  @@index([createdAt])
}

model CalendarConnection {
  id             String           @id @default(uuid())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  provider       CalendarProvider
  accountEmail   String?
  externalId     String?
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  metadata       Json?

  @@index([provider])
}

model CalendarEvent {
  id            String              @id @default(uuid())
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  contactId     String?
  inquiryId     String?
  appointmentId String?
  provider      CalendarProvider
  externalId    String?
  title         String
  description   String?
  startAt       DateTime
  endAt         DateTime?
  timezone      String?
  location      String?
  meetingUrl    String?
  status        CalendarEventStatus @default(scheduled)
  payload       Json?
  appointment   Appointment?        @relation(fields: [appointmentId], references: [id])
  contact       Contact?            @relation(fields: [contactId], references: [id])
  inquiry       Inquiry?            @relation(fields: [inquiryId], references: [id])

  @@index([provider, externalId])
  @@index([contactId])
  @@index([startAt])
  @@index([status])
}

enum PipelineStage {
  New
  Attempted_Contact
  Qualified
  Booked
  Sold
  Follow_Up
  Lost
}

enum ProductInterest {
  Mortgage_Protection
  Final_Expense
  Term_Life
  Whole_Life
  Child_Whole_Life
  Accident
  Critical_Illness
  IUL
  Annuity
  Retirement
  Business
  General
}

enum EventType {
  page_view
  cta_click
  call_click
  text_click
  email_click
  book_click
  form_submit
  lead_created
  appointment_booked
  stage_changed
  county_selected
  product_selected
  lead_magnet_download
  post_viewed
  post_created
  post_published
  reaction_added
}

enum ThreadChannel {
  sms
  email
}

enum MessageDirection {
  inbound
  outbound
}

enum MessageStatus {
  queued
  sent
  delivered
  failed
  received
  opened
  clicked
  bounced
}

enum AiRunStatus {
  queued
  running
  succeeded
  failed
}

enum AgentStepStatus {
  pending
  running
  succeeded
  failed
}

enum AiRunType {
  daily_brief
  draft_message
  contact_brief
  lead_score
  content_generation
  crm_assistant
  agent_workflow
}

enum ContentType {
  sms
  email
  social_post
  blog
  landing_page
}

enum ContentStatus {
  draft
  approved
  scheduled
  published
  archived
}

enum CalendarProvider {
  calendly
  google
  outlook
  manual
}

enum SocialProvider {
  linkedin
  facebook
  instagram
  twitter
}

model SocialConnection {
  id             String         @id @default(uuid())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  provider       SocialProvider
  accountName    String?
  externalId     String?
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  metadata       Json?
  status         String?

  @@index([provider])
  @@index([externalId])
}

enum CalendarEventStatus {
  scheduled
  confirmed
  completed
  cancelled
  no_show
  rescheduled
}

// ─── Social Engagement Dashboard ─────────────────────────────────────────────

enum SocialPostStatus {
  draft
  scheduled
  approved
  published
  failed
  archived
}

model SocialAccount {
  id             String   @id @default(cuid())
  platform       String
  accountName    String
  externalId     String
  accessTokenRef String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  posts SocialPost[]

  @@index([platform])
}

model SocialPost {
  id               String           @id @default(cuid())
  platform         String
  accountId        String?
  externalPostId   String?
  status           SocialPostStatus @default(draft)
  caption          String
  mediaUrls        Json?
  scheduledAt      DateTime?
  publishedAt      DateTime?
  approvedBy       String?
  campaign         String?
  rawPublishResult Json?
  metadata         Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  account  SocialAccount?  @relation(fields: [accountId], references: [id])
  metrics  SocialMetric[]
  comments SocialComment[]
  insights Insight[]

  @@unique([platform, externalPostId])
  @@index([platform])
  @@index([status])
  @@index([campaign])
}

model SocialMetric {
  id           String   @id @default(cuid())
  postId       String
  platform     String
  metricDate   DateTime
  impressions  Int      @default(0)
  reach        Int      @default(0)
  clicks       Int      @default(0)
  reactions    Int      @default(0)
  comments     Int      @default(0)
  shares       Int      @default(0)
  saves        Int      @default(0)
  leads        Int      @default(0)
  conversions  Int      @default(0)
  revenueCents Int      @default(0)
  raw          Json?
  createdAt    DateTime @default(now())

  post SocialPost @relation(fields: [postId], references: [id])

  @@unique([postId, metricDate])
  @@index([platform, metricDate])
}

model SocialComment {
  id                String   @id @default(cuid())
  postId            String
  platform          String
  externalCommentId String?
  authorHandle      String?
  body              String
  raw               Json?
  createdAt         DateTime @default(now())

  post     SocialPost   @relation(fields: [postId], references: [id])
  analyses AIAnalysis[]

  @@index([postId])
}

model AIAnalysis {
  id              String   @id @default(cuid())
  targetType      String
  targetId        String
  commentId       String?
  provider        String
  model           String
  sentiment       String
  confidence      Float
  intent          String?
  urgency         String?
  topics          Json
  trendingTerms   Json?
  leadPotential   String?
  complianceRisk  String?
  suggestedAction String?
  tokenEstimate   Int?
  costEstimate    Decimal? @db.Decimal(10, 6)
  latencyMs       Int?
  raw             Json?
  createdAt       DateTime @default(now())

  comment SocialComment? @relation(fields: [commentId], references: [id])

  @@index([targetType, targetId])
  @@index([sentiment, createdAt])
  @@index([provider, model])
}

model Insight {
  id        String   @id @default(cuid())
  type      String
  severity  String
  title     String
  summary   String
  action    String?
  source    Json?
  status    String   @default("open")
  postId    String?
  createdAt DateTime @default(now())

  post SocialPost? @relation(fields: [postId], references: [id])

  @@index([type, createdAt])
  @@index([severity, status])
}

model AutomationRule {
  id        String   @id @default(cuid())
  name      String
  trigger   Json
  condition Json
  actions   Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WeeklyReport {
  id              String   @id @default(cuid())
  weekStart       DateTime
  weekEnd         DateTime
  kpis            Json
  insights        Json
  opportunities   Json
  recommendations Json?
  pdfUrl          String?
  createdAt       DateTime @default(now())

  @@unique([weekStart, weekEnd])
  @@index([weekStart])
}

model UploadedWorkDocument {
  id            String   @id @default(cuid())
  fileName      String
  mimeType      String
  storageUrl    String?
  extractedText String?
  metadata      Json?
  status        String   @default("processed")
  createdAt     DateTime @default(now())

  @@index([mimeType])
  @@index([createdAt])
}

model SocialTemplate {
  id               String   @id @default(cuid())
  title            String
  category         String
  platform         String?
  audienceTrack    String?
  body             String
  cta              String?
  hashtags         Json?
  suggestedDay     String?
  suggestedTime    String?
  campaign         String?
  complianceStatus String   @default("draft")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  usages SocialTemplateUsage[]

  @@index([platform, category])
}

model SocialTemplateUsage {
  id          String   @id @default(cuid())
  templateId  String
  postId      String?
  usedAt      DateTime @default(now())
  performance Json?
  notes       String?

  template SocialTemplate @relation(fields: [templateId], references: [id])

  @@index([templateId])
}

enum AnalyticsJobStatus {
  queued
  running
  succeeded
  failed
  skipped
}

model AnalyticsDailyMetric {
  id         String   @id @default(cuid())
  metricDate DateTime
  metricKey  String
  value      Decimal  @db.Decimal(18, 4)
  unit       String   @default("count")
  source     String   @default("aggregation_job")
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([metricDate, metricKey])
  @@index([metricKey, metricDate])
}

model AnalyticsBreakdownDaily {
  id             String   @id @default(cuid())
  metricDate     DateTime
  metricKey      String
  dimension      String
  dimensionValue String
  value          Decimal  @db.Decimal(18, 4)
  unit           String   @default("count")
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([metricDate, metricKey, dimension, dimensionValue])
  @@index([dimension, dimensionValue, metricDate])
  @@index([metricKey, metricDate])
}

model AnalyticsFunnelDaily {
  id             String   @id @default(cuid())
  metricDate     DateTime
  funnelKey      String   @default("lead_funnel")
  stageKey       String
  stageOrder     Int
  count          Int
  conversionRate Decimal? @db.Decimal(8, 4)
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([metricDate, funnelKey, stageKey])
  @@index([funnelKey, metricDate])
}

model AnalyticsJobRun {
  id            String             @id @default(cuid())
  jobKey        String
  status        AnalyticsJobStatus @default(queued)
  startedAt     DateTime           @default(now())
  finishedAt    DateTime?
  targetStart   DateTime?
  targetEnd     DateTime?
  rowsProcessed Int                @default(0)
  error         String?
  metadata      Json?

  @@index([jobKey, startedAt])
  @@index([status, startedAt])
}

model AnalyticsTarget {
  id          String   @id @default(cuid())
  metricKey   String
  period      String   @default("weekly")
  targetValue Decimal  @db.Decimal(18, 4)
  active      Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([metricKey, period])
  @@index([active])
}

model ProcessedWebhook {
  id          String   @id @default(uuid())
  provider    String
  eventId     String
  processedAt DateTime @default(now())

  @@unique([provider, eventId])
  @@index([processedAt])
  @@map("processed_webhooks")
}

// ─────────────────────────────────────────────────────────────────────────────

enum LeadSource {
  WEBSITE_DIRECT
  GOOGLE_ORGANIC
  GOOGLE_ADS
  SOCIAL_ORGANIC
  QR_CAMPAIGN
  EMAIL_CAMPAIGN
  REFERRAL
  PARTNER_ORG
  PHONE_INBOUND
  SMS_INBOUND
  EMAIL_INBOUND
  EVENT
  WORKSHOP
  FILLOUT
  UNKNOWN
}

enum LeadIntent {
  CONSULT
  JOIN_PARTNERSHIP
  JOIN_AGENT
  JOIN_BOTH
  QUICK_TERM
  GENERAL_INQUIRY
  UNKNOWN
}

enum LeadStatus {
  NEW
  ATTEMPTED_CONTACT
  CONTACTED
  QUALIFIED
  BOOKED
  IN_CONSULT
  REFERRED_TO_ETHOS
  ETHOS_APPLIED
  ETHOS_APPROVED
  JOIN_EXPLORING
  JOIN_ONBOARDING
  JOIN_ACTIVE
  CLOSED_WON
  CLOSED_LOST
  NURTURE
  ON_HOLD
  DORMANT
}


model ContentResource {
  id          String   @id @default(cuid())
  title       String
  type        String
  status      String   @default("draft")
  bodyHtml    String?
  campaign    String?
  destination String?
  utmSource   String?
  publishAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  socialPublishJobs SocialPublishJob[]

  @@index([status, createdAt])
  @@index([campaign])
  @@index([publishAt])
}

model SocialPublishJob {
  id           String   @id @default(cuid())
  platform     String
  status       String   @default("queued")
  scheduledFor DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contentId String
  content   ContentResource @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([platform])
  @@index([status, scheduledFor])
  @@index([contentId])
}

// ─── Blog / Content Posts ─────────────────────────────────────────────────────

enum PostStatus {
  draft
  flagged
  approved
  published
  archived
}

model Post {
  id          String         @id @default(uuid())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  publishedAt DateTime?
  deletedAt   DateTime?
  slug        String         @unique
  title       String
  body        String
  tags        String[]
  status      PostStatus     @default(draft)
  viewCount   Int            @default(0)
  createdBy   String?
  comments    PostComment[]
  reactions   PostReaction[]

  @@index([status, publishedAt])
  @@index([deletedAt])
  @@index([createdBy])
}

model PostReaction {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  postId    String
  userId    String
  emoji     String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, emoji])
  @@index([postId])
}

model PostComment {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  postId    String
  authorId  String?
  body      String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

model WorkflowTemplate {
  id           String         @id @default(cuid())
  name         String
  description  String?
  triggerType  String         // manual | webhook | cron | crm_stage
  triggerValue String?        // cron expr, stage name, webhook key
  category     String?
  tags         String[]       @default([])
  isPreset     Boolean        @default(false)
  isActive     Boolean        @default(false)
  runCount     Int            @default(0)
  lastRunAt    DateTime?
  steps        WorkflowStep[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([triggerType])
  @@index([isActive])
  @@index([isPreset])
}

model WorkflowStep {
  id         String           @id @default(cuid())
  workflowId String
  order      Int
  type       String           // email | sms | social_post | ai_generate | delay | condition
  label      String
  config     Json
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  workflow   WorkflowTemplate @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, order])
}
