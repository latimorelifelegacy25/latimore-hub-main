# Latimore Hub OS — local/deployment environment template
# Copy to .env.local for local development.
# In Vercel, set these as encrypted Project Environment Variables.

# -----------------------------------------------------------------------------
# Database — Supabase PostgreSQL
# -----------------------------------------------------------------------------
# Use the pooled/transaction connection for app runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"

# Use the direct connection for Prisma migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"


# Supabase API / CRM intake
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# -----------------------------------------------------------------------------
# Authentication — NextAuth + Google OAuth
# -----------------------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"

# Comma-separated allowlist for protected admin users.
ADMIN_EMAILS="jackson1989@latimorelegacy.com"

# Emergency local-only bypass. Must remain false in Vercel/production.
DISABLE_ADMIN_AUTH="false"

# -----------------------------------------------------------------------------
# Email — Resend
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_replace_with_resend_key"
LEAD_NOTIFY_EMAIL="jackson1989@latimorelegacy.com"
NOTIFY_TO="leads@latimorelegacy.com"
THANKYOU_FROM="Latimore Life & Legacy <hello@latimorelegacy.com>"

# -----------------------------------------------------------------------------
# Webhooks
# -----------------------------------------------------------------------------
FILLOUT_SECRET="replace-with-fillout-signing-secret"
GOOGLE_CHAT_WEBHOOK_URL=""
BOOKING_WEBHOOK_SECRET="replace-with-random-booking-webhook-secret"

# -----------------------------------------------------------------------------
# Public site URLs and analytics
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
GA4_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_GA4_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_META_PIXEL_ID="000000000000000"
NEXT_PUBLIC_TIKTOK_PIXEL_ID=""
META_CAPI_ACCESS_TOKEN=""

# -----------------------------------------------------------------------------
# Optional runtime services
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
LOG_LEVEL="info"
NEXT_TELEMETRY_DISABLED="1"
