# ─── Database (Supabase / Prisma) ────────────────────────────────────────────
# Pooled connection (port 6543) — used at runtime
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) — used for migrations only
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ─── Supabase (for PAHS standalone table or direct Supabase calls) ────────────
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."   # service_role secret — never expose client-side

# ─── NextAuth / Admin Auth ────────────────────────────────────────────────────
NEXTAUTH_URL="https://hub.latimorelifelegacy.com"
NEXTAUTH_SECRET=""                   # generate: openssl rand -base64 32

# Comma-separated list of Google accounts allowed to access /admin
ADMIN_EMAILS="jackson@latimorelifelegacy.com"

# Set true ONLY for local/debug — never in production
DISABLE_ADMIN_AUTH=false

# ─── Google OAuth (for NextAuth Google provider) ─────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Google Calendar (optional — for appointment sync) ───────────────────────
GOOGLE_CALENDAR_ID=""
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_SERVICE_ACCOUNT_KEY=""        # full JSON key as single line

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
NOTIFY_TO="jackson@latimorelifelegacy.com"
THANKYOU_FROM="Latimore Life & Legacy <noreply@latimorelifelegacy.com>"

# Legacy aliases (used by pahs-lead route — falls back to NOTIFY_TO/THANKYOU_FROM)
LEAD_NOTIFY_TO=
LEAD_NOTIFY_FROM=

# ─── AI Provider ─────────────────────────────────────────────────────────────
# Use "openai" (default) or "gemini"
AI_PROVIDER=openai
OPENAI_API_KEY="sk-..."
GEMINI_API_KEY=""

# ─── PAHS Lead Routing ────────────────────────────────────────────────────────
# "crm"      → writes Contact/Inquiry/Task/Event into the Hub CRM via Prisma
# "supabase" → writes to a standalone Supabase table (PAHS_LEADS_TABLE)
PAHS_LEAD_TARGET=crm
PAHS_LEADS_TABLE=pahs_leads            # only used when PAHS_LEAD_TARGET=supabase

# ─── Webhooks & Cron ─────────────────────────────────────────────────────────
FILLOUT_SECRET=""                    # HMAC-SHA256 secret from Fillout dashboard
CRON_SECRET=""                       # shared secret for cron job auth header

# ─── Public / Client-side ────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="https://hub.latimorelifelegacy.com"
NEXT_PUBLIC_GA4_ID=""                # legacy alias — prefer NEXT_PUBLIC_MAIN_GA4_ID

# GA4 — three-property setup per SPEC-2
NEXT_PUBLIC_MAIN_GA4_ID="G-S0Q3E4DEBJ"     # main website (source of truth)
NEXT_PUBLIC_CAMPAIGN_GA4_ID="G-D4SCQZT4T9" # campaign / funnel / landing pages (optional)
NEXT_PUBLIC_APP_GA4_ID="G-KVM9W2SM21"      # admin / internal product analytics (optional)

# ─── Social Engagement / SPEC-2 ──────────────────────────────────────────────
# Engagement sync token (used by external schedulers to POST /api/analytics/social/sync)
ENGAGEMENT_SYNC_TOKEN=""

# Weekly report generation token (for external cron trigger)
WEEKLY_REPORT_TOKEN=""

# Document upload protection (not used server-side; token is for optional API gateway)
DOCUMENT_UPLOAD_TOKEN=""

# Meta (Facebook/Instagram) lead ads webhook
META_APP_SECRET=""              # App Secret from Meta App Dashboard
META_PAGE_ACCESS_TOKEN=""       # Page-level access token (long-lived)
META_WEBHOOK_VERIFY_TOKEN=""    # Random string you set in Meta webhook config

# LinkedIn lead gen bridge
LINKEDIN_INGEST_TOKEN=""        # Bearer token for /api/social/linkedin/ingest

# AI model routing (3-tier: Gemini → OpenAI → Claude)
ANTHROPIC_API_KEY=""            # Used as final escalation for sentiment analysis
GEMINI_SENTIMENT_MODEL="gemini-2.0-flash-lite"
OPENAI_SENTIMENT_MODEL="gpt-4.1-nano"
CLAUDE_SENTIMENT_MODEL="claude-haiku-4-5-20251001"
