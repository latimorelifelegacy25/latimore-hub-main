{
  "name": "latimorehub",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "build:safe": "prisma generate && NODE_OPTIONS=--max-old-space-size=2048 NEXT_TELEMETRY_DISABLED=1 next build",
    "build:clean": "rm -rf .next node_modules/.cache .turbo && npm run build:safe",
    "start": "next start",
    "lint": "eslint app components lib middleware.ts next.config.js postcss.config.js tailwind.config.ts --ext .js,.jsx,.ts,.tsx --no-error-on-unmatched-pattern",
    "validate": "npm run preflight && npm run lint && npm run build",
    "postinstall": "prisma generate",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "build:fresh-db": "prisma generate && prisma db push && next build",
    "db:seed": "tsx prisma/seed.ts",
    "check": "tsx scripts/verify-workspace.ts",
    "analytics:validate": "ts-node --transpile-only scripts/validate-analytics.ts",
    "preflight": "node scripts/preflight.mjs",
    "smoke": "node scripts/smoke.mjs"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@hello-pangea/dnd": "^16.6.0",
    "@next/third-parties": "^16.2.6",
    "@notionhq/client": "^5.22.0",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@supabase/supabase-js": "^2.105.4",
    "@upstash/ratelimit": "^1.2.1",
    "@upstash/redis": "^1.31.3",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "framer-motion": "^12.40.0",
    "gsap": "^3.12.5",
    "lucide-react": "^0.378.0",
    "marked": "^18.0.4",
    "next": "^15.2.1",
    "next-auth": "^4.24.7",
    "next-mdx-remote": "^6.0.0",
    "pino": "^9.2.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "reading-time": "^1.5.0",
    "recharts": "^2.15.4",
    "resend": "^3.2.0",
    "slugify": "^1.6.9",
    "tailwind-merge": "^2.3.0",
    "twilio": "^5.4.0",
    "zod": "^3.23.8",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^16.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.22.0",
    "eslint-config-next": "^16.2.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "pino-pretty": "^10.3.1",
    "postcss": "^8.4.38",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.19.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.57.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
