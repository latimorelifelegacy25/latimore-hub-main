{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "crons": [
    { "path": "/api/cron/daily-brief", "schedule": "0 8 * * *" },
    { "path": "/api/cron/lead-score-updates", "schedule": "0 * * * *" },
    { "path": "/api/cron/appointment-reminders", "schedule": "0 9 * * *" },
    { "path": "/api/cron/notification-checks", "schedule": "*/15 * * * *" }
  ],
  "rewrites": [
    { "source": "/webhooks/notion", "destination": "/api/webhooks/notion" }
  ]
}
