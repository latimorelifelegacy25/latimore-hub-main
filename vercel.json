{
  "framework": "nextjs",
  "buildCommand": "npm run build:safe",
  "crons": [
    {
      "path": "/api/cron/daily-brief",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/lead-score-updates",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/appointment-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/notification-checks",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/social-publisher",
      "schedule": "*/15 * * * *"
    }
  ]
}
